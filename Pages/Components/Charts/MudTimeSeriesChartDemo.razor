@page "/components/timeserieschart"
@using MudBlazor

<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
    `MudTimeSeriesChart` is not available in MudBlazor 9. This demo now uses a standard line chart with formatted time labels to preserve a similar reference view.
</MudAlert>

<MudPaper Class="doc-section-component-container">
    <MudChart T="double" ChartType="ChartType.Line" ChartSeries="@_series" @bind-SelectedIndex="_index" LegendPosition="@LegendPosition"
        Width="@_width" Height="@_height" ChartOptions="@_options"
        ChartLabels="@_xAxisLabels" CanHideSeries="_canHideSeries" MatchBoundsToSize="@_matchBoundsToSize" />
</MudPaper>

<MudGrid>
    <MudItem xs="12">
        <MudText Typo="Typo.body1" Class="py-3">Selected: @(_index < 0 ? "None" : _series[_index].Name)</MudText>
    </MudItem>

    <MudItem xs="6" md="6">
        <MudCheckBox @bind-Value="_matchBoundsToSize" Color="Color.Primary" Label="MatchBoundsToSize">
        </MudCheckBox>
        <MudCheckBox @bind-Value="_showDataMarkers" Color="Color.Primary"
            Label="Show Data Markers"></MudCheckBox>
        <MudSlider @bind-Value="_options.LineStrokeWidth" Min="1" Max="10">Line Width:
            @_options.LineStrokeWidth.ToString()</MudSlider>
    </MudItem>

    <MudItem md="6" xs="6">
        <MudTextField @bind-Value="_width" Label="Chart Width"></MudTextField>
        <MudTextField Class="mt-3" @bind-Value="_height" Label="Chart Height"></MudTextField>
        <MudSelect Label="Legend Position" Variant="Variant.Outlined" Dense="true" T="@Position"
            ValueChanged="OnSelectedValue" Class="mt-6">
            <MudSelectItem T="Position" Value="Position.Top">Top</MudSelectItem>
            <MudSelectItem T="Position" Value="Position.Left">Left</MudSelectItem>
            <MudSelectItem T="Position" Value="Position.Right">Right</MudSelectItem>
            <MudSelectItem T="Position" Value="Position.Bottom">Bottom</MudSelectItem>
            <MudSelectItem T="Position" Value="Position.Start">Start</MudSelectItem>
            <MudSelectItem T="Position" Value="Position.End">End</MudSelectItem>
        </MudSelect>
        <MudSwitch @bind-Value="_canHideSeries" Color="Color.Secondary" Label="Hide Series" />
    </MudItem>

</MudGrid>

@code {
    private int _index = -1; //default value cannot be 0 -> first selectedindex is 0.
    private LineChartOptions _options = new LineChartOptions
    {
        YAxisLines = false,
        YAxisTicks = 500,
        MaxNumYAxisTicks = 10,
        YAxisRequireZeroPoint = true,
        XAxisLines = false,
        LineStrokeWidth = 1,
    };

    private readonly List<ChartSeries<double>> _series = new();
    private string[] _xAxisLabels = [];

    private readonly Random _random = new Random();

    private string _width = "650px";
    private string _height = "350px";
    private bool _matchBoundsToSize;
    private bool _showDataMarkers;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _options.ShowDataMarkers = _showDataMarkers;

        var now = DateTime.Now;
        var points = Enumerable.Range(0, 24).ToList();
        _xAxisLabels = points.Select(i => now.AddMinutes(i * 15).ToString("HH:mm")).ToArray();
        _series.Add(new ChartSeries<double> { Name = "Series 1", Data = points.Select(_ => (double)_random.Next(6000, 15000)).ToArray() });
        _series.Add(new ChartSeries<double> { Name = "Series 2", Data = points.Select(_ => (double)_random.Next(0, 7000)).ToArray() });
        _series.Add(new ChartSeries<double> { Name = "Series 3", Data = points.Select(_ => (double)_random.Next(4000, 10000)).ToArray() });
    }

    private bool _canHideSeries = true;

    public Position LegendPosition { get; set; } = Position.Bottom;

    private void OnSelectedValue(Position value)
    {
        switch (value)
        {
            case Position.Top:
                LegendPosition = Position.Top;
                break;
            case Position.Left:
                LegendPosition = Position.Left;
                break;
            case Position.Right:
                LegendPosition = Position.Right;
                break;
            case Position.Bottom:
                LegendPosition = Position.Bottom;
                break;
            case Position.Start:
                LegendPosition = Position.Start;
                break;
            case Position.End:
                LegendPosition = Position.End;
                break;
        }
    }

    protected override void OnParametersSet()
    {
        _options.ShowDataMarkers = _showDataMarkers;
    }
}
