@page "/components/buttongroup"
@using MudBlazor

<DemoPageLayout Title="Button Group"
                Description="Groups related MudButton components together visually."
                Variant="DemoPageLayoutVariant.Vertical">
    <Preview>
        <div class="d-flex flex-wrap justify-center align-center w-100" style="column-gap: 24px; row-gap: 12px">
            <div style="@PrimaryGroupStyle">
                <MudButtonGroup Color="@_color"
                                Variant="@_variant"
                                Size="@_size"
                                Vertical="@_vertical"
                                DropShadow="@_dropShadow"
                                FullWidth="@_fullWidth">
                    <MudButton>One</MudButton>
                    <MudButton>Two</MudButton>
                    <MudButton>Three</MudButton>
                </MudButtonGroup>
            </div>

            <div style="@SecondaryGroupStyle">
                <MudButtonGroup Color="@_color"
                                Variant="@_variant"
                                Size="@_size"
                                Vertical="@_vertical"
                                DropShadow="@_dropShadow"
                                FullWidth="@_fullWidth">
                    <MudIconButton Icon="@Icons.Material.Filled.AccessAlarm"
                                   Color="@ResolvedIconColor"
                                   Style="@ResolvedIconStyle" />
                    <MudToggleIconButton Icon="@Icons.Material.Filled.AlarmOff"
                                         ToggledIcon="@Icons.Material.Filled.AlarmOn"
                                         Color="@ResolvedIconColor"
                                         ToggledColor="@ResolvedIconColor"
                                         Style="@ResolvedIconStyle" />
                    <MudButton StartIcon="@Icons.Material.Filled.AlarmAdd"
                               Color="@_color">
                        Add Alarm
                    </MudButton>
                </MudButtonGroup>
            </div>
        </div>
    </Preview>

    <Options>
        <MudGrid Spacing="4" Justify="Justify.Center" Class="w-100">
            <MudItem xs="12" md="6">
                <MudSelect T="Variant"
                           Label="Variant"
                           Dense="true"
                           @bind-Value="_variant">
                    <MudSelectItem Value="Variant.Text">Text</MudSelectItem>
                    <MudSelectItem Value="Variant.Outlined">Outlined</MudSelectItem>
                    <MudSelectItem Value="Variant.Filled">Filled</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="Color"
                           Label="Color"
                           Dense="true"
                           @bind-Value="_color">
                    <MudSelectItem Value="Color.Default">Default</MudSelectItem>
                    <MudSelectItem Value="Color.Primary">Primary</MudSelectItem>
                    <MudSelectItem Value="Color.Secondary">Secondary</MudSelectItem>
                    <MudSelectItem Value="Color.Tertiary">Tertiary</MudSelectItem>
                    <MudSelectItem Value="Color.Info">Info</MudSelectItem>
                    <MudSelectItem Value="Color.Success">Success</MudSelectItem>
                    <MudSelectItem Value="Color.Warning">Warning</MudSelectItem>
                    <MudSelectItem Value="Color.Error">Error</MudSelectItem>
                    <MudSelectItem Value="Color.Dark">Dark</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12">
                <MudSelect T="Size"
                           Label="Size"
                           Dense="true"
                           @bind-Value="_size">
                    <MudSelectItem Value="Size.Small">Small</MudSelectItem>
                    <MudSelectItem Value="Size.Medium">Medium</MudSelectItem>
                    <MudSelectItem Value="Size.Large">Large</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12">
                <div class="d-flex flex-wrap align-center justify-start" style="column-gap: 16px; row-gap: 4px;">
                    <MudCheckBox @bind-Value="_vertical" Label="Vertical" Color="Color.Primary" />
                    <MudCheckBox @bind-Value="_fullWidth" Label="Full Width" Color="Color.Primary" />
                    <MudCheckBox @bind-Value="_dropShadow" Label="Drop Shadow" Color="Color.Primary" />
                </div>
            </MudItem>

        </MudGrid>
    </Options>
</DemoPageLayout>

@code {
    private Variant _variant = Variant.Text;
    private Color _color = Color.Default;
    private Size _size = Size.Medium;
    private bool _vertical;
    private bool _fullWidth;
    private bool _dropShadow = true;

    private string PrimaryGroupStyle => _fullWidth ? "width: min(100%, 420px);" : string.Empty;
    private string SecondaryGroupStyle => _fullWidth ? "width: min(100%, 520px);" : string.Empty;
    private Color ResolvedIconColor => NormalizeIconOnlyColor(_color);
    private string? ResolvedIconStyle => ShouldUseLightIconColor ? "color: white !important;" : null;

    private Color NormalizeIconOnlyColor(Color color)
    {
        if (_variant != Variant.Filled)
            return color;

        return color switch
        {
            Color.Primary or
            Color.Secondary or
            Color.Tertiary or
            Color.Info or
            Color.Success or
            Color.Warning or
            Color.Error or
            Color.Dark => Color.Inherit,
            _ => color
        };
    }

    private bool ShouldUseLightIconColor =>
        _variant == Variant.Filled &&
        _color != Color.Default;
}
