@page "/components/iconbutton"
@using MudBlazor

<DemoPageLayout Title="Icon Button"
                Description="A clickable icon for actions and commands."
                Variant="DemoPageLayoutVariant.Vertical">
    <Preview>
        <MudStack Spacing="2" AlignItems="AlignItems.Center" Class="w-100">
            <MudIconButton Icon="@_icon"
                           Color="@_color"
                           Size="@_size"
                           Edge="@_edge"
                           Variant="@_variant"
                           Disabled="@_disabled"
                           Ripple="@_ripple"
                           Href="@ResolvedHref"
                           Target="@ResolvedTarget"
                           aria-label="@_ariaLabel"
                           OnClick="OnIconButtonClick" />

            <MudText Typo="Typo.caption">
                Clicked: @_clickedCount
            </MudText>
        </MudStack>
    </Preview>

    <Options>
        <MudGrid Spacing="4" Justify="Justify.Center" Class="w-100">
            <MudItem xs="12" md="6">
                <MudSelect T="string"
                           Label="Icon"
                           Dense="true"
                           @bind-Value="_icon">
                    <MudSelectItem Value="@Icons.Material.Filled.Favorite">Favorite</MudSelectItem>
                    <MudSelectItem Value="@Icons.Material.Filled.Edit">Edit</MudSelectItem>
                    <MudSelectItem Value="@Icons.Material.Filled.Delete">Delete</MudSelectItem>
                    <MudSelectItem Value="@Icons.Material.Filled.Share">Share</MudSelectItem>
                    <MudSelectItem Value="@Icons.Material.Filled.Settings">Settings</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="Variant"
                           Label="Variant"
                           Dense="true"
                           @bind-Value="_variant">
                    <MudSelectItem Value="Variant.Text">Text</MudSelectItem>
                    <MudSelectItem Value="Variant.Outlined">Outlined</MudSelectItem>
                    <MudSelectItem Value="Variant.Filled">Filled</MudSelectItem>
                </MudSelect>
            </MudItem>

                <MudItem xs="12" md="6">
                <MudSelect T="Color"
                           Label="Color"
                           Dense="true"
                           @bind-Value="_color">
                    <MudSelectItem Value="Color.Default">Default</MudSelectItem>
                    <MudSelectItem Value="Color.Primary">Primary</MudSelectItem>
                    <MudSelectItem Value="Color.Secondary">Secondary</MudSelectItem>
                    <MudSelectItem Value="Color.Tertiary">Tertiary</MudSelectItem>
                    <MudSelectItem Value="Color.Info">Info</MudSelectItem>
                    <MudSelectItem Value="Color.Success">Success</MudSelectItem>
                    <MudSelectItem Value="Color.Warning">Warning</MudSelectItem>
                    <MudSelectItem Value="Color.Error">Error</MudSelectItem>
                    <MudSelectItem Value="Color.Dark">Dark</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="Size"
                           Label="Size"
                           Dense="true"
                           @bind-Value="_size">
                    <MudSelectItem Value="Size.Small">Small</MudSelectItem>
                    <MudSelectItem Value="Size.Medium">Medium</MudSelectItem>
                    <MudSelectItem Value="Size.Large">Large</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudSelect T="Edge"
                           Label="Edge"
                           Dense="true"
                           @bind-Value="_edge">
                    <MudSelectItem Value="Edge.False">None</MudSelectItem>
                    <MudSelectItem Value="Edge.Start">Start</MudSelectItem>
                    <MudSelectItem Value="Edge.End">End</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudTextField Label="Aria Label"
                              @bind-Value="_ariaLabel" />
            </MudItem>

            <MudItem xs="12">
                <div class="d-flex flex-wrap align-center justify-start" style="column-gap: 16px; row-gap: 4px;">
                    <MudCheckBox @bind-Value="_disabled" Label="Disabled" Color="Color.Primary" />
                    <MudCheckBox @bind-Value="_ripple" Label="Ripple" Color="Color.Primary" />
                    <MudCheckBox @bind-Value="_linkMode" Label="Link Mode" Color="Color.Primary" />
                    @if (_linkMode)
                    {
                        <MudCheckBox @bind-Value="_openInNewTab" Label="Open In New Tab" Color="Color.Primary" />
                    }
                </div>
            </MudItem>

            @if (_linkMode)
            {
                <MudItem xs="12">
                    <MudTextField Label="Href"
                                  @bind-Value="_href" />
                </MudItem>
            }
        </MudGrid>
    </Options>
</DemoPageLayout>

@code {
    private string _icon = Icons.Material.Filled.Favorite;
    private Color _color = Color.Default;
    private Size _size = Size.Medium;
    private Edge _edge = Edge.False;
    private Variant _variant = Variant.Text;
    private string _ariaLabel = "favorite";
    private bool _disabled;
    private bool _ripple = true;
    private bool _linkMode;
    private bool _openInNewTab = true;
    private string _href = "https://github.com/m1n3g/mudblazor-component-playground";
    private int _clickedCount;

    private string? ResolvedHref => _linkMode ? _href : null;
    private string? ResolvedTarget => _linkMode && _openInNewTab ? "_blank" : null;

    private void OnIconButtonClick(MouseEventArgs _)
    {
        if (!_disabled)
            _clickedCount++;
    }
}
