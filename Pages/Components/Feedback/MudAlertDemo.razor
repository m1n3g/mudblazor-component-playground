@page "/components/alert"
@using MudBlazor

<MudStack Spacing="1" Class="mb-4 px-2 px-sm-5 py-2">
    <MudText Typo="Typo.h5" Style="font-weight: 600;">
        Alert
    </MudText>

    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-primary);">
        Displays an important message which is statically embedded in the page content.
    </MudText>
</MudStack>

<MudGrid Spacing="0">
    <!-- PREVIEW: Top on xs/md, right side on lg+ -->
    <MudItem xs="12" md="12" lg="7" Class="order-1 order-lg-2 px-2 px-sm-0 mb-4 mb-lg-0">
        <MudPaper Class="pa-0 pa-sm-5 pa-lg-6 h-100 d-flex flex-column justify-center" Elevation="0">
            <div class="d-flex justify-center">
                <MudAlert Class="w-100"
                          Style="max-width: 800px;"
                          Severity="@_severity"
                          Variant="@_variant"
                          Dense="@_dense"
                          NoIcon="@_noIcon"
                          Square="@IsSquare"
                          Elevation="@_elevation"
                          ContentAlignment="@_contentAlignment"
                          ShowCloseIcon="@_showCloseIcon"
                          CloseIcon="@_closeIcon"
                          Icon="@SelectedIcon"
                          CloseIconClicked="OnClosed"
                          OnClick="OnAlertClicked">

                    @_content
                </MudAlert>
            </div>

            <MudText Typo="Typo.caption" Class="mt-3 text-center">
                Clicked: @_clickedCount | Closed: @_closedCount
            </MudText>
        </MudPaper>
    </MudItem>

    <!-- OPTIONS: Below on xs/md, left side on lg+ -->
    <MudItem xs="12" md="12" lg="5" Class="order-2 order-lg-1 px-2 px-sm-0">
        <MudPaper Class="pa-2 pa-sm-5 pa-lg-6 h-100 me-lg-6 d-flex flex-column gap-2" Elevation="0">
            <MudSelect T="Variant" Label="Variant" Dense="true" @bind-Value="_variant">
                <MudSelectItem Value="Variant.Filled">Filled</MudSelectItem>
                <MudSelectItem Value="Variant.Outlined">Outlined</MudSelectItem>
                <MudSelectItem Value="Variant.Text">Text</MudSelectItem>
            </MudSelect>

            <MudSelect T="Severity" Label="Severity" Dense="true" @bind-Value="_severity">
                <MudSelectItem Value="Severity.Normal">Normal</MudSelectItem>
                <MudSelectItem Value="Severity.Info">Info</MudSelectItem>
                <MudSelectItem Value="Severity.Success">Success</MudSelectItem>
                <MudSelectItem Value="Severity.Warning">Warning</MudSelectItem>
                <MudSelectItem Value="Severity.Error">Error</MudSelectItem>
            </MudSelect>

            <div class="d-flex flex-wrap align-center gap-1">
                <MudCheckBox @bind-Value="_dense"
                             Label="Dense"
                             Color="Color.Primary" />

                <MudCheckBox @bind-Value="_noIcon"
                             Label="No Icon"
                             Color="Color.Primary" />
            </div>

            <MudSelect T="AlertShape" Label="Corners" Dense="true" @bind-Value="_shape">
                <MudSelectItem Value="AlertShape.Default">Theme Default</MudSelectItem>
                <MudSelectItem Value="AlertShape.Square">Square</MudSelectItem>
            </MudSelect>

            <MudText Typo="Typo.caption" Class="mud-secondary-text" Style="line-height: 1.5;">
                Rounded corners are controlled by the app theme in MudBlazor 9.6, not by a direct MudAlert parameter.
            </MudText>

            <MudSlider Min="0"
                       Max="25"
                       Step="1"
                       @bind-Value="_elevation"
                       Color="Color.Info">
                Elevation
            </MudSlider>

            <MudSelect T="HorizontalAlignment"
                       Label="Content Alignment"
                       Dense="true"
                       @bind-Value="_contentAlignment">
                <MudSelectItem Value="HorizontalAlignment.Left">Left</MudSelectItem>
                <MudSelectItem Value="HorizontalAlignment.Center">Center</MudSelectItem>
                <MudSelectItem Value="HorizontalAlignment.Right">Right</MudSelectItem>
                <MudSelectItem Value="HorizontalAlignment.Start">Start</MudSelectItem>
                <MudSelectItem Value="HorizontalAlignment.End">End</MudSelectItem>
            </MudSelect>

            <MudTextField Label="Alert Content"
                          @bind-Value="_content" />

            <MudSelect T="string"
                       Label="Icon"
                       Dense="true"
                       @bind-Value="_iconSelection">
                <MudSelectItem Value="@DefaultIconOption">Default by severity</MudSelectItem>
                <MudSelectItem Value="@Icons.Material.Filled.NotificationsActive">Notifications Active</MudSelectItem>
                <MudSelectItem Value="@Icons.Material.Filled.Campaign">Campaign</MudSelectItem>
                <MudSelectItem Value="@Icons.Material.Filled.Bolt">Bolt</MudSelectItem>
                <MudSelectItem Value="@Icons.Material.Filled.Star">Star</MudSelectItem>
            </MudSelect>

            <MudCheckBox @bind-Value="_showCloseIcon"
                         Label="Show Close Icon"
                         Color="Color.Primary" />

            <MudSelect T="string"
                       Label="Close Icon"
                       Dense="true"
                       @bind-Value="_closeIcon"
                       Disabled="@(!_showCloseIcon)">
                <MudSelectItem Value="@Icons.Material.Filled.Close">Close</MudSelectItem>
                <MudSelectItem Value="@Icons.Material.Filled.Cancel">Cancel</MudSelectItem>
                <MudSelectItem Value="@Icons.Material.Filled.Clear">Clear</MudSelectItem>
                <MudSelectItem Value="@Icons.Material.Filled.Done">Done</MudSelectItem>
            </MudSelect>
        </MudPaper>
    </MudItem>
</MudGrid>


@code {
    // Core options
    private Variant _variant = Variant.Filled;
    private Severity _severity = Severity.Info;
    private bool _dense;
    private bool _noIcon;

    // Shape
    private AlertShape _shape = AlertShape.Default;
    private bool IsSquare => _shape == AlertShape.Square;

    // Elevation
    private int _elevation = 0;

    // Content + alignment (built-in)
    private string _content = "This is a customizable MudAlert.";
    private HorizontalAlignment _contentAlignment = HorizontalAlignment.Left;

    // Icon + close icon
    private const string DefaultIconOption = "__DEFAULT__";
    private string _iconSelection = DefaultIconOption;
    private string _closeIcon = Icons.Material.Filled.Close;

    // Events
    private bool _showCloseIcon = true;
    private int _clickedCount;
    private int _closedCount;

    private string? SelectedIcon => _iconSelection == DefaultIconOption ? null : _iconSelection;

    private void OnAlertClicked(MouseEventArgs _)
        => _clickedCount++;

    private void OnClosed(MudAlert? _ = null) => _closedCount++; // event fires on close icon click

    private enum AlertShape { Default, Square }
}
