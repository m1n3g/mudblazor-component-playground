@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider IsDarkMode="_isDark" />

<MudLayout Class="app-shell">
    <MudAppBar Elevation="1" Color="Color.Primary" Fixed="true" Dense="false">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
            OnClick="ToggleDrawer" />

        <div class="app-shell-title-wrap">
            <MudText Typo="Typo.h6" Class="app-shell-title">MudPlayground</MudText>
        </div>
        <MudSpacer />

        <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Href="https://github.com/m1n3g/mudblazor-component-playground"
            Color="Color.Inherit" Target="_blank" Rel="noopener noreferrer" />

        <MudIconButton Color="Color.Inherit"
            Icon="@(_isDark ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
            aria-label="Toggle theme" OnClick="ToggleTheme" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Responsive" Elevation="0" Width="260px"
        Anchor="Anchor.Start" Breakpoint="Breakpoint.Md" ClipMode="DrawerClipMode.Always"
        Class="app-shell-drawer">
        <div class="app-shell-drawer-content">
            <NavMenu />
        </div>
    </MudDrawer>

    <MudMainContent Class="app-shell-main">
        <div class="app-shell-body">
            @Body
        </div>
    </MudMainContent>

</MudLayout>

@code {
    private bool _drawerOpen = true;
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private bool _isDark;

    private void ToggleTheme() => _isDark = !_isDark;
}
