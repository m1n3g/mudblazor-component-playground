@using Microsoft.AspNetCore.Components

<MudStack Spacing="1" Class="demo-page-title mb-4 py-2 px-0 mx-auto w-100" Style="@($"max-width: {ContentMaxWidth};")">
    <MudText Typo="Typo.h5" Style="font-weight: 600;">
        @Title
    </MudText>

    @if (!string.IsNullOrWhiteSpace(Description))
    {
        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-primary);">
            @Description
        </MudText>
    }
</MudStack>

@switch (Variant)
{
    case DemoPageLayoutVariant.Horizontal:
        <div class="demo-page-content demo-page-horizontal mx-auto d-flex flex-column gap-4" style="@($"max-width: {ContentMaxWidth};")">
            <div class="demo-page-panels">
                <MudPaper Class="demo-page-preview py-3 py-lg-6 px-0 d-flex flex-column align-center justify-center gap-3" Elevation="0">
                    @RenderPreview()
                </MudPaper>

                <MudPaper Class="demo-page-options py-0 py-lg-3 px-0 w-100 d-flex flex-column" Elevation="0">
                    @Options
                </MudPaper>
            </div>
        </div>
        break;

    case DemoPageLayoutVariant.PreviewOnly:
        <div class="demo-page-content mx-auto d-flex flex-column gap-4" style="@($"max-width: {ContentMaxWidth};")">
            <MudPaper Class="demo-page-preview py-3 py-lg-6 px-0 d-flex flex-column align-center justify-center gap-3" Elevation="0">
                @RenderPreview()
            </MudPaper>
        </div>
        break;

    case DemoPageLayoutVariant.Custom:
        <div class="demo-page-content mx-auto d-flex flex-column gap-4" style="@($"max-width: {ContentMaxWidth};")">
            @CustomContent
        </div>
        break;

    case DemoPageLayoutVariant.Vertical:
    default:
        <div class="demo-page-content mx-auto d-flex flex-column gap-4" style="@($"max-width: {ContentMaxWidth};")">
            <MudPaper Class="demo-page-preview py-3 py-lg-6 px-0 d-flex flex-column align-center justify-center gap-3" Elevation="0">
                @RenderPreview()
            </MudPaper>

            <MudPaper Class="demo-page-options py-0 py-lg-3 px-0 w-100 d-flex flex-column" Elevation="0">
                @Options
            </MudPaper>
        </div>
        break;
}

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public DemoPageLayoutVariant Variant { get; set; } = DemoPageLayoutVariant.Vertical;

    [Parameter]
    public string ContentMaxWidth { get; set; } = "1120px";

    [Parameter]
    public string PreviewContentMaxWidth { get; set; } = "800px";

    [Parameter]
    public bool ConstrainPreviewContent { get; set; } = true;

    [Parameter]
    public RenderFragment? Preview { get; set; }

    [Parameter]
    public RenderFragment? Options { get; set; }

    [Parameter]
    public RenderFragment? CustomContent { get; set; }

    private RenderFragment RenderPreview() => builder =>
    {
        if (ConstrainPreviewContent)
        {
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "class", "w-100 mx-auto");
            builder.AddAttribute(2, "style", $"max-width: {PreviewContentMaxWidth};");
            builder.AddContent(3, Preview);
            builder.CloseElement();
        }
        else
        {
            builder.AddContent(4, Preview);
        }
    };
}
